---
const stats = [
  { num: "8–10", unit: "km/s", label: "Tug ΔV / lifetime" },
  { num: "~150", unit: "km",   label: "Pod apogee target" },
  { num: "≥10",  unit: "×",    label: "Tug reuse cycles" },
  { num: "0",    unit: "kg",   label: "Pod propellant to TLI" },
];
---
<section class="hero" aria-labelledby="hero-h" id="top">
  <canvas id="hero-stars" aria-hidden="true"></canvas>
  <div class="grid-bg" aria-hidden="true"></div>
  <div class="wrap hero-inner">
    <div class="eyebrow">
      <span class="eyebrow-num">00</span>
      <span class="eyebrow-text">Concept brief</span>
    </div>
    <h1 id="hero-h">
      Cargo to <span class="accent">cislunar</span><br/>
      on a reusable <span class="accent-2">Tug</span>.
    </h1>
    <p class="lede">
      A rail launch lofts a ballistic pod to apogee. A reusable Tug — already
      circling in a phasing orbit — performs apogee rendezvous, captures the pod,
      and burns trans-lunar injection. The Tug returns. The pod continues to the Moon.
    </p>
    <div class="hero-stats" role="list">
      {stats.map(s => (
        <div class="stat" role="listitem">
          <div class="stat-num">{s.num}<span class="stat-unit">{s.unit}</span></div>
          <div class="stat-label">{s.label}</div>
        </div>
      ))}
    </div>
    <div class="cta-row">
      <a class="btn btn-primary" href="#orbit">See the orbit</a>
      <a class="btn" href="#dv">Run the ΔV calc →</a>
    </div>
    <div class="scroll-cue" aria-hidden="true">
      <span>Scroll</span>
      <svg viewBox="0 0 12 24" width="12" height="24"><path d="M6 2 V20 M2 16 L6 20 L10 16" stroke="currentColor" stroke-width="1.2" fill="none" stroke-linecap="round"/></svg>
    </div>
  </div>
</section>

<script>
  // Star field — vanilla canvas, GPU-cheap
  const c = document.getElementById("hero-stars") as HTMLCanvasElement | null;
  if (c) {
    const ctx = c.getContext("2d")!;
    const dpr = Math.min(window.devicePixelRatio || 1, 2);
    let w = 0, h = 0;
    const stars: { x:number; y:number; r:number; tw:number; ph:number }[] = [];

    function resize() {
      w = c!.clientWidth;
      h = c!.clientHeight;
      c!.width  = w * dpr;
      c!.height = h * dpr;
      ctx.setTransform(dpr,0,0,dpr,0,0);
      stars.length = 0;
      const n = Math.round((w * h) / 4500);
      for (let i = 0; i < n; i++) {
        stars.push({
          x: Math.random() * w,
          y: Math.random() * h,
          r: Math.random() * 1.2 + 0.2,
          tw: 0.4 + Math.random() * 0.6,
          ph: Math.random() * Math.PI * 2,
        });
      }
    }

    function frame(t: number) {
      ctx.clearRect(0, 0, w, h);
      for (const s of stars) {
        const a = 0.35 + 0.55 * (0.5 + 0.5 * Math.sin(t * 0.0008 * s.tw + s.ph));
        ctx.fillStyle = `rgba(216,230,245,${a})`;
        ctx.beginPath();
        ctx.arc(s.x, s.y, s.r, 0, Math.PI * 2);
        ctx.fill();
      }
      requestAnimationFrame(frame);
    }

    if (!matchMedia("(prefers-reduced-motion: reduce)").matches) {
      resize();
      window.addEventListener("resize", resize);
      requestAnimationFrame(frame);
    }
  }
</script>

<style>
.hero {
  position: relative;
  min-height: 86vh;
  display: flex; align-items: center;
  overflow: hidden;
  border-bottom: 1px solid var(--c-line);
  background: radial-gradient(ellipse at 70% 30%, rgba(255,184,77,.04), transparent 50%), var(--c-bg);
}
#hero-stars {
  position: absolute; inset: 0;
  width: 100%; height: 100%;
}
.grid-bg {
  position: absolute; inset: 0;
  background-image:
    linear-gradient(rgba(31,48,80,.25) 1px, transparent 1px),
    linear-gradient(90deg, rgba(31,48,80,.25) 1px, transparent 1px);
  background-size: 56px 56px;
  mask-image: radial-gradient(ellipse at 50% 50%, #000 30%, transparent 75%);
}
.hero-inner { position: relative; padding: 120px 0 100px; }
h1 { margin-top: 8px; max-width: 18ch; }
.accent   { color: var(--c-accent); }
.accent-2 { color: var(--c-accent-2); }
.lede { margin-top: 24px; }

.hero-stats {
  display: grid; gap: 20px;
  grid-template-columns: repeat(auto-fit, minmax(190px, 1fr));
  margin: 56px 0 36px;
  max-width: 920px;
}
.stat {
  border-left: 2px solid var(--c-accent);
  padding: 6px 0 6px 16px;
}
.stat-num {
  font-family: var(--f-display);
  font-weight: 600;
  font-size: 38px;
  line-height: 1;
  color: var(--c-fg);
}
.stat-unit {
  font-family: var(--f-mono);
  font-size: 14px;
  color: var(--c-fg-dim);
  margin-left: 6px;
}
.stat-label {
  font-family: var(--f-mono);
  font-size: 11px;
  color: var(--c-fg-dim);
  letter-spacing: 0.14em;
  text-transform: uppercase;
  margin-top: 8px;
}

.cta-row { display: flex; gap: 12px; flex-wrap: wrap; margin-top: 12px; }

.scroll-cue {
  position: absolute; bottom: 32px; left: 50%; transform: translateX(-50%);
  display: flex; flex-direction: column; align-items: center; gap: 8px;
  color: var(--c-fg-dim);
  font-family: var(--f-mono); font-size: 11px; letter-spacing: 0.16em; text-transform: uppercase;
  animation: bob 2.2s ease-in-out infinite;
}
@keyframes bob {
  0%,100% { transform: translate(-50%, 0); opacity: .8; }
  50%     { transform: translate(-50%, 6px); opacity: 1; }
}
</style>
